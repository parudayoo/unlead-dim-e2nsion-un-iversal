local function onCharAdded(chr)
    local hr =chr:WaitForChild("HumanoidRootPart",10)
    local hum=chr:WaitForChild("Humanoid",10)
    if not hr or not hum then return end
    hum.WalkSpeed=State.walkSpeed; hum.JumpPower=State.jumpPower
    guardHumanoidStats(hum)  -- WalkSpeed/JumpPower/Sit/PlatformStand/Ragdoll監視も内包
    claimOwnership()
    if State.fixBody then
        for _,p in ipairs(chr:GetDescendants()) do
            if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then
                p.LocalTransparencyModifier=1
            end
        end
    end
    task.delay(1.2,function()
        guardedPos=hr.Position; guardActive=false; startPositionGuard()
    end)
end
LP.CharacterAdded:Connect(onCharAdded)
