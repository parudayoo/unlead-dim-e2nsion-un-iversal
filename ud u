UserInputService.InputBegan:Connect(function(inp,gpe)
    if gpe then return end

    -- Rocket [P]
    if inp.KeyCode==Enum.KeyCode.P and State.rocket then
        local hr=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if hr then
            local exp=Instance.new("Explosion"); exp.Position=hr.Position
            exp.BlastRadius=0; exp.BlastPressure=0; exp.Parent=Workspace
            task.delay(0.5,function() pcall(function() exp:Destroy() end) end)
            local bv=Instance.new("BodyVelocity")
            bv.Velocity=Vector3.new(0,220,0)
            bv.MaxForce=Vector3.new(0,math.huge,0); bv.Parent=hr
            task.delay(0.35,function() pcall(function() bv:Destroy() end) end)
        end
    end

    -- Recon [E]
    if inp.KeyCode==Enum.KeyCode.E and State.recon then
        local chr=LP.Character
        local hr=chr and chr:FindFirstChild("HumanoidRootPart")
        if not hr then return end
        local rp=RaycastParams.new()
        rp.FilterDescendantsInstances={chr}; rp.FilterType=Enum.RaycastFilterType.Exclude
        local res=Workspace:Raycast(hr.Position,Camera.CFrame.LookVector*4,rp)
        local tgt=res and (res.Position+res.Normal*2) or (hr.Position+Camera.CFrame.LookVector)
        hr.CFrame=CFrame.new(tgt); hr.Velocity=Vector3.zero
        task.delay(3,function()
            for _,plr in ipairs(Players:GetPlayers()) do
                if plr~=LP and plr.Character then
                    local ehr=plr.Character:FindFirstChild("HumanoidRootPart")
                    if ehr and (hr.Position-ehr.Position).Magnitude<=250 then
                        local sb=Instance.new("SelectionBox")
                        sb.Color3=Color3.fromRGB(255,0,0); sb.LineThickness=0.06
                        sb.Adornee=plr.Character; sb.Parent=Workspace
                        task.delay(5,function() pcall(function() sb:Destroy() end) end)
                    end
                end
            end
        end)
    end

    -- Follow [J]  ─ トグル
    if inp.KeyCode==Enum.KeyCode.J then
        if not State.selectedPlayer then
            -- 選択なしのとき警告
            local warn=Instance.new("TextLabel",ScreenGui)
            warn.Size=UDim2.new(0,280,0,36)
            warn.Position=UDim2.new(0.5,-140,0,10)
            warn.BackgroundColor3=Color3.fromRGB(80,20,20)
            warn.Text="⚠  プレイヤーを先に選択してください"
            warn.TextColor3=Color3.fromRGB(255,100,100)
            warn.Font=Enum.Font.GothamBold; warn.TextSize=12
            warn.BorderSizePixel=0
            Instance.new("UICorner",warn).CornerRadius=UDim.new(0,8)
            task.delay(2,function() pcall(function() warn:Destroy() end) end)
            return
        end
        State.follow=not State.follow
        followTrack.BackgroundColor3=State.follow and C.orange or C.toggleOff
        TweenService:Create(followThumb,TweenInfo.new(0.15),{
            Position=State.follow and UDim2.new(0,21,0.5,-7) or UDim2.new(0,3,0.5,-7)
        }):Play()

        -- Follow ON → 追跡中は位置ガード無効化
        if State.follow then
            guardActive=false  -- 追跡中は位置ガード停止（自分が動くため）
        else
            -- Follow OFF → 位置ガード再開
            local hr=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if hr then guardedPos=hr.Position end
            guardActive=false; startPositionGuard()
        end
    end

    -- Show / Hide [右Ctrl]
    if inp.KeyCode==Enum.KeyCode.RightControl then
        MainFrame.Visible=not MainFrame.Visible
    end

    -- Block Remote Teleport [4キー]
    if inp.KeyCode==Enum.KeyCode.Four then
        State.blockRemoteTeleport = not State.blockRemoteTeleport
        -- 画面に通知トースト
        local toast=Instance.new("TextLabel",ScreenGui)
        toast.Size=UDim2.new(0,300,0,36)
        toast.Position=UDim2.new(0.5,-150,0,10)
        toast.BackgroundColor3=State.blockRemoteTeleport
            and Color3.fromRGB(20,80,30)
            or  Color3.fromRGB(60,30,20)
        toast.Text=State.blockRemoteTeleport
            and "🔒 Remote Teleport ブロック ON"
            or  "🔓 Remote Teleport ブロック OFF"
        toast.TextColor3=State.blockRemoteTeleport
            and Color3.fromRGB(100,255,130)
            or  Color3.fromRGB(255,160,80)
        toast.Font=Enum.Font.GothamBold; toast.TextSize=13
        toast.BorderSizePixel=0
        Instance.new("UICorner",toast).CornerRadius=UDim.new(0,8)
        -- フェードアウト
        task.delay(1.5,function()
            TweenService:Create(toast,TweenInfo.new(0.5),{TextTransparency=1,BackgroundTransparency=1}):Play()
            task.delay(0.5,function() pcall(function() toast:Destroy() end) end)
        end)
    end
end)

