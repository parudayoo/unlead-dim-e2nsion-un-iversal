-- ESPヒットボックス管理テーブル
local hitboxBoxes = {}   -- [player] = SelectionBox

RunService.RenderStepped:Connect(function(dt)
    local chr=LP.Character; if not chr then return end
    local hr =chr:FindFirstChild("HumanoidRootPart")
    local hum=chr:FindFirstChildWhichIsA("Humanoid")
    if not hr or not hum then return end

    -- ── FLY ─────────────────────────────────────────────────
    if State.fly then
        local bp=hr:FindFirstChild("FlyBP")
        local bg=hr:FindFirstChild("FlyBG")
        if not bp then
            bp=Instance.new("BodyPosition"); bp.Name="FlyBP"
            bp.MaxForce=Vector3.new(math.huge,math.huge,math.huge)
            bp.P=1e5; bp.D=500; bp.Position=hr.Position; bp.Parent=hr
        end
        if not bg then
            bg=Instance.new("BodyGyro"); bg.Name="FlyBG"
            bg.MaxTorque=Vector3.new(math.huge,math.huge,math.huge)
            bg.P=1e4; bg.Parent=hr
        end
        local dir=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir+=Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir-=Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir-=Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir+=Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)       then dir+=Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir-=Vector3.yAxis end
        if dir.Magnitude>0 then dir=dir.Unit end
        bp.Position=bp.Position+dir*State.flySpeed*dt
        bg.CFrame=Camera.CFrame
        hum.PlatformStand=true
    else
        for _,n in ipairs({"FlyBP","FlyBG"}) do
            local m=hr:FindFirstChild(n); if m then m:Destroy() end
        end
        if hum.PlatformStand and not State.walkingFly then hum.PlatformStand=false end
    end

    -- ── WALKING FLY ─────────────────────────────────────────
    if State.walkingFly and not State.fly then
        local wbp=hr:FindFirstChild("WalkFlyBP") or Instance.new("BodyPosition")
        wbp.Name="WalkFlyBP"; wbp.MaxForce=Vector3.new(0,math.huge,0)
        wbp.P=1e5; wbp.Position=Vector3.new(hr.Position.X,hr.Position.Y+3,hr.Position.Z)
        wbp.Parent=hr; hum.WalkSpeed=State.walkingFlySpeed
    else
        local w=hr:FindFirstChild("WalkFlyBP"); if w then w:Destroy() end
    end

    -- ── NOCLIP ──────────────────────────────────────────────
    if State.noclip then
        for _,p in ipairs(chr:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=false end
        end
    end

    -- ── ANTI KNOCKBACK ───────────────────────────────────────
    if State.antiKnockback then
        pcall(function() applyAntiKnockback(hr) end)
    end

    -- ── FIX BODY ────────────────────────────────────────────
    if State.fixBody then
        for _,p in ipairs(chr:GetDescendants()) do
            if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then
                p.LocalTransparencyModifier=1
            end
        end
    end

    -- ── ESP + HITBOX ─────────────────────────────────────────
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr==LP then continue end
        local pChr=plr.Character
        local ehr=pChr and pChr:FindFirstChild("HumanoidRootPart")

        -- ESP 名前タグ
        if State.esp and ehr then
            local dist=(hr.Position-ehr.Position).Magnitude
            local tag=ehr:FindFirstChild("ESP_BB")
            if dist>=90 and dist<=250 then
                if not tag then
                    local bb=Instance.new("BillboardGui"); bb.Name="ESP_BB"
                    bb.Size=UDim2.new(0,90,0,22); bb.StudsOffset=Vector3.new(0,4,0)
                    bb.AlwaysOnTop=true; bb.Parent=ehr
                    local tl=Instance.new("TextLabel",bb)
                    tl.Size=UDim2.new(1,0,1,0); tl.BackgroundTransparency=1
                    tl.TextColor3=Color3.fromRGB(255,60,60)
                    tl.Font=Enum.Font.GothamBold; tl.TextSize=12
                end
                local tl=ehr.ESP_BB:FindFirstChildWhichIsA("TextLabel")
                if tl then tl.Text=plr.Name.." ["..math.floor(dist).."m]" end
            else
                if tag then tag:Destroy() end
            end
        else
            if ehr then
                local tag=ehr:FindFirstChild("ESP_BB")
                if tag then tag:Destroy() end
            end
        end

        -- ESP HITBOX (SelectionBox)
        if State.espHitbox and pChr and ehr then
            local dist=(hr.Position-ehr.Position).Magnitude
            if dist<=300 then
                if not hitboxBoxes[plr] then
                    local sb=Instance.new("SelectionBox")
                    sb.Name="ESPHitbox"
                    sb.Color3=Color3.fromRGB(255,50,50)
                    sb.SurfaceColor3=Color3.fromRGB(255,50,50)
                    sb.SurfaceTransparency=0.85
                    sb.LineThickness=0.04
                    sb.Adornee=pChr
                    sb.Parent=Workspace
                    hitboxBoxes[plr]=sb
                end
            else
                if hitboxBoxes[plr] then
                    hitboxBoxes[plr]:Destroy(); hitboxBoxes[plr]=nil
                end
            end
        else
            -- ESPHitbox OFF なら全削除
            if hitboxBoxes[plr] then
                hitboxBoxes[plr]:Destroy(); hitboxBoxes[plr]=nil
            end
        end
    end

    -- ── FOLLOW (追跡) ────────────────────────────────────────
    if State.follow and State.selectedPlayer then
        local tChr=State.selectedPlayer.Character
        local thr =tChr and tChr:FindFirstChild("HumanoidRootPart")
        if thr then
            -- 対象の後ろ5スタッドに配置
            local behindPos = thr.CFrame * CFrame.new(0,0,5)
            local fp=hr:FindFirstChild("FollowBP") or Instance.new("BodyPosition")
            fp.Name="FollowBP"
            fp.MaxForce=Vector3.new(math.huge,math.huge,math.huge)
            fp.P=3e4; fp.D=800
            fp.Position=behindPos.Position
            fp.Parent=hr
            -- 同じ方向を向く
            local bg2=hr:FindFirstChild("FollowBG") or Instance.new("BodyGyro")
            bg2.Name="FollowBG"
            bg2.MaxTorque=Vector3.new(math.huge,math.huge,math.huge)
            bg2.P=5000
            bg2.CFrame=thr.CFrame; bg2.Parent=hr
            hum.PlatformStand=true
        end
    else
        for _,n in ipairs({"FollowBP","FollowBG"}) do
            local m=hr:FindFirstChild(n); if m then m:Destroy() end
        end
        if not State.fly and hum.PlatformStand then hum.PlatformStand=false end
    end

    -- ── WalkSpeed 常時保護 (毎フレームではなくずれ検知時のみ) ──
    -- guardHumanoidStats でイベント監視しているのでここでは不要
end)

