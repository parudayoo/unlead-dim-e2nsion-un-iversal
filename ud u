-- [AC-3] NetworkOwnership 定期取得
local function claimOwnership()
    pcall(function()
        local chr = LP.Character; if not chr then return end
        for _, p in ipairs(chr:GetDescendants()) do
            if p:IsA("BasePart") then
                pcall(function() p:SetNetworkOwner(LP) end)
            end
        end
    end)
end
task.spawn(function() while task.wait(0.8) do claimOwnership() end end)

-- [AC-4] WalkSpeed 引き戻し対策
--   Humanoid.WalkSpeed を外部から書き換えられたら即座に戻す
local function guardHumanoidStats(hum)
    if not hum then return end
    pcall(function()
        -- WalkSpeed 監視
        hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            local expected = State.speedBoost and (State.walkSpeed+30) or State.walkSpeed
            if math.abs(hum.WalkSpeed - expected) > 0.5 then
                task.wait()
                pcall(function() hum.WalkSpeed = expected end)
            end
        end)
        -- JumpPower 監視
        hum:GetPropertyChangedSignal("JumpPower"):Connect(function()
            if math.abs(hum.JumpPower - State.jumpPower) > 0.5 then
                task.wait()
                pcall(function() hum.JumpPower = State.jumpPower end)
            end
        end)
        -- Sit 強制解除
        hum:GetPropertyChangedSignal("Sit"):Connect(function()
            if hum.Sit then task.wait(); pcall(function() hum.Sit = false end) end
        end)
        -- PlatformStand 監視（Fly以外では解除）
        hum:GetPropertyChangedSignal("PlatformStand"):Connect(function()
            if not State.fly and hum.PlatformStand then
                task.wait(); pcall(function() hum.PlatformStand = false end)
            end
        end)

        -- ラグドール無効: HumanoidStateType.Ragdoll / FallingDown を即座にキャンセル
        hum.StateChanged:Connect(function(_, new)
            if State.antiRagdoll then
                if new == Enum.HumanoidStateType.Ragdoll
                or new == Enum.HumanoidStateType.FallingDown then
                    task.wait()
                    pcall(function()
                        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                    end)
                end
            end
        end)
    end)
end

-- 吹っ飛び無効: HumanoidRootPart の Velocity を毎フレーム監視してキャンセル
-- (RenderSteppedループ内で処理するため関数化)
local function applyAntiKnockback(hr)
    -- Velocity が大きすぎるとき水平方向をゼロに戻す
    local vel = hr.AssemblyLinearVelocity
    -- 垂直（Y）は Fly/Rocket/Jump で使うので水平のみ制限
    local horizSpeed = Vector2.new(vel.X, vel.Z).Magnitude
    if horizSpeed > 60 then
        hr.AssemblyLinearVelocity = Vector3.new(0, vel.Y, 0)
    end
end

-- [AC-5] 位置監視ガード
local guardedPos  = nil
local guardActive = false
local guardPaused = false

local function startPositionGuard()
    if guardActive then return end
    guardActive = true
    task.spawn(function()
        while guardActive do
            task.wait(0.05)
            if guardPaused then continue end
            local chr = LP.Character
            local hr  = chr and chr:FindFirstChild("HumanoidRootPart")
            if hr and guardedPos then
                local delta = (hr.Position - guardedPos).Magnitude
                -- 追跡中は大きく動くので判定を緩める
                local threshold = State.follow and 999 or 60
                if delta > threshold then
                    pcall(function()
                        hr.CFrame      = CFrame.new(guardedPos)
                        hr.Velocity    = Vector3.zero
                        hr.RotVelocity = Vector3.zero
                    end)
                end
            end
            if hr then guardedPos = hr.Position end
        end
    end)
end

-- [AC-6] RemoteEvent フック（位置リセット系をブロック）
--   State.blockRemoteTeleport が true のときだけ無視する
local function hookRemotes()
    pcall(function()
        for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
            if v:IsA("RemoteEvent") then
                pcall(function()
                    v.OnClientEvent:Connect(function(...)
                        -- blockRemoteTeleport ON のときだけ何もしない
                        -- OFF のときは通常通りゲーム側の処理が動く
                        -- ※ここでは「追加リスナー」として登録するだけなので
                        --   ゲーム本来の処理は別のConnectで動き続ける
                        if State.blockRemoteTeleport then return end
                    end)
                end)
            end
        end
    end)
    ReplicatedStorage.DescendantAdded:Connect(function(v)
        if v:IsA("RemoteEvent") then
            pcall(function()
                v.OnClientEvent:Connect(function(...)
                    if State.blockRemoteTeleport then return end
                end)
            end)
        end
    end)
end
task.spawn(hookRemotes)

-- ============================================================
--  SAFE TELEPORT
-- ============================================================
local function safeTeleport(targetPos)
    local chr = LP.Character
    local hr  = chr and chr:FindFirstChild("HumanoidRootPart")
    if not hr then return end
    local hum = chr:FindFirstChildWhichIsA("Humanoid")

    guardPaused = true

    -- 干渉する BodyMover を一時削除
    for _, name in ipairs({"FlyBP","FlyBG","WalkFlyBP","TpBP","FollowBP"}) do
        local m = hr:FindFirstChild(name); if m then m:Destroy() end
    end
    if hum then hum.PlatformStand = false end

    local dest = targetPos + Vector3.new(0, 3, 0)
    local bp = Instance.new("BodyPosition")
    bp.Name = "TpBP"; bp.MaxForce = Vector3.new(math.huge,math.huge,math.huge)
    bp.P = 2e6; bp.D = 2000; bp.Position = dest; bp.Parent = hr

    task.spawn(function()
        for i = 1, 10 do
            task.wait()
            pcall(function()
                hr.CFrame = CFrame.new(dest)
                hr.Velocity = Vector3.zero; hr.RotVelocity = Vector3.zero
            end)
        end
        task.wait(0.3)
        pcall(function() bp:Destroy() end)

        -- Fly再アタッチ
        if State.fly then
            local newBP = Instance.new("BodyPosition"); newBP.Name="FlyBP"
            newBP.MaxForce=Vector3.new(math.huge,math.huge,math.huge)
            newBP.P=1e5; newBP.D=500; newBP.Position=dest; newBP.Parent=hr
            local newBG = Instance.new("BodyGyro"); newBG.Name="FlyBG"
            newBG.MaxTorque=Vector3.new(math.huge,math.huge,math.huge)
            newBG.P=1e4; newBG.Parent=hr
            if hum then hum.PlatformStand=true end
        end

        guardedPos  = dest
        guardPaused = false
    end)
end

